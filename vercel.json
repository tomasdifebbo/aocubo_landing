{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist/public",
                "installCommand": "npm install --legacy-peer-deps"
            }
        },
        {
            "src": "api/index.ts",
            "use": "@vercel/node",
            "config": {
                "installCommand": "npm install --legacy-peer-deps"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.ts"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}